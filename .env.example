# ============================================================
# Unfilter Environment Variables
# ============================================================
# Copy this to .env.local and fill in your values

# JWT secret — generate a random string for production
# openssl rand -base64 32
JWT_SECRET=change-this-to-a-random-secret-in-production

# App URL — used for verification email links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Trusted IP header — REQUIRED in production behind any proxy.
# Leave UNSET in local dev. Setting the wrong value, or leaving it blank
# behind a proxy that does NOT strip client-supplied X-Forwarded-For,
# allows attackers to bypass per-IP rate limits and brute-force logins.
TRUSTED_IP_HEADER=

# SMTP for verification + password reset emails (optional in dev — emails log to console)
# For Gmail: enable "App Passwords" in Google account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# OAuth providers (optional — enables "Continue with Google/Microsoft" buttons)
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft: https://portal.azure.com → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Auth.js secret — required for OAuth session encryption
# openssl rand -base64 32
AUTH_SECRET=change-this-to-a-random-secret-in-production

# NOTE: Unfilter stores ONLY auth credentials on the server.
# All skin data (photos, journal, routines, check-ins) stays
# on the user's device in localStorage.
# The SQLite database at data/auth.db contains ONLY:
# - user ID, username, email, hashed password, verification status
